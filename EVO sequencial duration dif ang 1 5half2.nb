Cell[BoxData[{
 RowBox[{
  RowBox[{"pieceEach", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotpieceNumber", "=", 
   RowBox[{"pieceEach", "*", 
    RowBox[{"(", 
     RowBox[{"ExtraPiece", "+", "1"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotpieceTable", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "PlotpieceNumber"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"j", "==", "1"}], ",", 
         RowBox[{
          RowBox[{"PlotpieceTable", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "=", 
          RowBox[{"\[Xi]Squre", "[", 
           RowBox[{
            RowBox[{"UHmuti", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Last", "[", "\[Phi]Table", "]"}], "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"Last", "[", "\[Phi]Table", "]"}], "[", 
               RowBox[{"[", "2", "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"Last", "[", "\[Phi]Table", "]"}], "[", 
               RowBox[{"[", "3", "]"}], "]"}], ",", 
              RowBox[{"totT", "*", 
               FractionBox["i", "pieceEach"]}]}], "]"}], ".", 
            RowBox[{"State\[Theta]\[Phi]Initial", "[", 
             RowBox[{
              FractionBox["Pi", "2"], ",", 
              FractionBox["Pi", "2"]}], "]"}]}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"PlotpieceTable", "[", 
           RowBox[{"[", 
            RowBox[{"i", "+", 
             RowBox[{"pieceEach", "*", 
